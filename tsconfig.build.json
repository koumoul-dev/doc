{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "declaration": true,
    "allowImportingTsExtensions": false,
    "rewriteRelativeImportExtensions": true
  },
  "include": [
    "src/env.d.ts",
    "src/cli/**/*.ts",
    "src/vite/**/*.ts",
    "src/markdown/**/*.ts",
    "src/themes/resolve.ts",
    "src/types.ts"
  ]
}
